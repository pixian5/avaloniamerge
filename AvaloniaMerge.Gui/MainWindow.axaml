<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:AvaloniaMerge.Gui.ViewModels"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="720"
        x:Class="AvaloniaMerge.Gui.MainWindow"
        Title="AvaloniaMerge" Width="1100" Height="720" MinWidth="900" MinHeight="600">
    <Design.DataContext>
        <vm:MainViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="*" Margin="24">
        <Border Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="18" Padding="20">
            <Grid RowDefinitions="Auto,Auto,*" RowSpacing="16">
                <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="12" RowSpacing="10">
                    <TextBlock Text="左侧路径" VerticalAlignment="Center" />
                    <TextBox Grid.Column="1" Text="{Binding LeftPath}" Watermark="选择文件或目录" />
                    <Button Grid.Column="2" Content="文件" Classes="subtle" Click="OnBrowseLeftFile" />
                    <Button Grid.Column="3" Content="目录" Classes="subtle" Click="OnBrowseLeftFolder" />

                    <TextBlock Grid.Row="1" Text="右侧路径" VerticalAlignment="Center" />
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding RightPath}" Watermark="选择文件或目录" />
                    <Button Grid.Row="1" Grid.Column="2" Content="文件" Classes="subtle" Click="OnBrowseRightFile" />
                    <Button Grid.Row="1" Grid.Column="3" Content="目录" Classes="subtle" Click="OnBrowseRightFolder" />
                </Grid>

                <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <RadioButton GroupName="CompareTarget"
                                         Content="自动识别"
                                         Classes="mode-button"
                                         IsChecked="{Binding IsAutoCompareTarget}" />
                            <RadioButton GroupName="CompareTarget"
                                         Content="文件差异"
                                         Classes="mode-button"
                                         IsChecked="{Binding IsFileCompareTarget}" />
                            <RadioButton GroupName="CompareTarget"
                                         Content="目录差异"
                                         Classes="mode-button"
                                         IsChecked="{Binding IsDirectoryCompareTarget}" />
                        </StackPanel>
                        <TextBlock Text="比较方法" VerticalAlignment="Center" />
                        <ComboBox ItemsSource="{Binding DirectoryCompareMethods}" SelectedItem="{Binding SelectedDirectoryCompareMethod}" Width="160" />
                        <CheckBox Content="忽略大小写" IsChecked="{Binding IgnoreCase}" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding Summary}" Foreground="{DynamicResource MutedTextBrush}" VerticalAlignment="Center" />
                    </StackPanel>
                    <Button Grid.Column="1" Content="交换" Classes="subtle" Click="OnSwap" />
                    <Button Grid.Column="2" Content="对比" Classes="primary" Click="OnCompare" />
                </Grid>

                <Grid Grid.Row="2" RowDefinitions="Auto,*" RowSpacing="8">
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource MutedTextBrush}" />
                    <TabControl Grid.Row="1" SelectedIndex="{Binding SelectedTab}">
                        <TabItem Header="文件差异">
                            <Border Background="White" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="12" Padding="12">
                                <ScrollViewer>
                                    <ItemsControl ItemsSource="{Binding FileDiffLines}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{Binding Background}" CornerRadius="6" Padding="8,4" Margin="0,0,0,6">
                                                    <TextBlock Text="{Binding DisplayText}" Foreground="{Binding Foreground}" FontFamily="Menlo, Consolas, monospace" />
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>
                        </TabItem>
                        <TabItem Header="目录差异">
                            <Border Background="White" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="12" Padding="12">
                                <Grid RowDefinitions="Auto,*" RowSpacing="12">
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <TextBlock Text="筛选" VerticalAlignment="Center" />
                                        <ComboBox ItemsSource="{Binding DirectoryFilterOptions}" SelectedItem="{Binding DirectoryFilter}" Width="120" />
                                        <TextBlock Text="搜索" VerticalAlignment="Center" />
                                        <TextBox Text="{Binding DirectorySearchText}" Width="200" Watermark="路径关键字" />
                                        <TextBlock Text="排序" VerticalAlignment="Center" />
                                        <ComboBox ItemsSource="{Binding DirectorySortOptions}" SelectedItem="{Binding DirectorySort}" Width="140" />
                                        <CheckBox Content="降序" IsChecked="{Binding DirectorySortDescending}" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding DirectoryCountText}" Foreground="{DynamicResource MutedTextBrush}" VerticalAlignment="Center" />
                                    </StackPanel>

                                    <Grid Grid.Row="1" RowDefinitions="Auto,*" RowSpacing="6">
                                        <Border Background="#F3F4F6" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="8" Padding="8,6">
                                            <Grid ColumnDefinitions="2*,90,100,100,160,160" ColumnSpacing="8">
                                                <TextBlock Text="路径" FontWeight="SemiBold" />
                                                <TextBlock Grid.Column="1" Text="状态" FontWeight="SemiBold" />
                                                <TextBlock Grid.Column="2" Text="左大小" FontWeight="SemiBold" />
                                                <TextBlock Grid.Column="3" Text="右大小" FontWeight="SemiBold" />
                                                <TextBlock Grid.Column="4" Text="左修改时间" FontWeight="SemiBold" />
                                                <TextBlock Grid.Column="5" Text="右修改时间" FontWeight="SemiBold" />
                                            </Grid>
                                        </Border>

                                        <ScrollViewer Grid.Row="1">
                                            <ItemsControl ItemsSource="{Binding DirectoryItems}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="White" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="8" Padding="10,6" Margin="0,0,0,8"
                                                                DoubleTapped="OnDirectoryItemDoubleTapped">
                                                            <Border.ContextMenu>
                                                                <ContextMenu>
                                                                    <MenuItem Header="复制到左侧" Click="OnCopyToLeft" Tag="{Binding}" IsVisible="{Binding IsOnlyRight}" />
                                                                    <MenuItem Header="删除" Click="OnDeleteRight" Tag="{Binding}" IsVisible="{Binding IsOnlyRight}" />
                                                                    <MenuItem Header="打开双方上级文件夹" Click="OnOpenParentFolders" Tag="{Binding}" />
                                                                </ContextMenu>
                                                            </Border.ContextMenu>
                                                            <Grid ColumnDefinitions="2*,90,100,100,160,160" ColumnSpacing="8">
                                                                <TextBlock Text="{Binding DisplayPath}" TextWrapping="Wrap" />
                                                                <Border Grid.Column="1" Background="{Binding StatusBrush}" CornerRadius="6" Padding="6,2" HorizontalAlignment="Left">
                                                                    <TextBlock Text="{Binding StatusLabel}" FontSize="12" />
                                                                </Border>
                                                                <TextBlock Grid.Column="2" Text="{Binding LeftSizeDisplay}" />
                                                                <TextBlock Grid.Column="3" Text="{Binding RightSizeDisplay}" />
                                                                <TextBlock Grid.Column="4" Text="{Binding LeftModifiedDisplay}" />
                                                                <TextBlock Grid.Column="5" Text="{Binding RightModifiedDisplay}" />
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Grid>
                                </Grid>
                            </Border>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
